# STC Colorado FSA State Committee app — environment variables template.
#
# Copy to .env for local dev:  cp .env.example .env
# .env is gitignored. Never commit real values.
#
# Production values live in the Render dashboard (Environment tab).
# Names are declared in render.yaml with sync: false — Render does not
# overwrite dashboard values on deploy.

# --- Server ---
# Port the Node server listens on. Render sets this automatically in prod;
# for local dev, default is 3000.
PORT=3000

# Bind address. 0.0.0.0 accepts external connections; 127.0.0.1 is localhost-only.
HOST=0.0.0.0

# --- Data persistence ---
# Directory for the SQLite database and uploaded files.
# Local dev: leave unset to use server/data/ (gitignored).
# Production: set to the mounted disk path (e.g. /var/data on Render).
# DATA_DIR=/var/data

# Optional overrides for individual paths. Default: ${DATA_DIR}/pfa.db and ${DATA_DIR}/uploads.
# SQLITE_PATH=/var/data/pfa.db
# UPLOADS_DIR=/var/data/uploads

# --- Microsoft Entra authentication (server-side token verification) ---
# From the Entra app registration in the MCCONNELL ENTERPRISES tenant.
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- Microsoft Entra authentication (client-side MSAL) ---
# Must be prefixed VITE_ to be exposed to the browser build.
# Values are identical to the server-side TENANT_ID / CLIENT_ID above.
VITE_MICROSOFT_TENANT_ID=
VITE_MICROSOFT_CLIENT_ID=

# --- SharePoint document sync (via Microsoft Graph) ---
# Full URL of the SharePoint site. Example:
#   https://<tenant>.sharepoint.com/sites/<site-name>
SHAREPOINT_SITE_URL=

# Document library name. Default is "Shared Documents" if unset.
SHAREPOINT_LIBRARY=Shared Documents

# Folder inside the library that the Teams watcher polls.
# Default is "FSA - State Committee" if unset.
SHAREPOINT_WATCH_FOLDER=FSA - State Committee
